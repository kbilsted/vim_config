" cd c:\users\<user>
" git init 
" git config --global --add safe.directory C:/Users/<user>
" git remote add origin https://github.com/kbilsted/vim_config.git
" git pull origin master
"
"
" to reload the config use ':source c:\users\<user>\.vsvimrc'


" get current line + relative numbers better than 'set relativenumber'
set number relativenumber 	

" Sets system synchronized clipboard register 
set clipboard=unnamed       

" The number of screen lines to keep above and below the cursor.
set scrolloff=9 

" escape substitute 

" -- search --
"DONT SET 'set hlsearch' since we have to clear highlight again
"enable incremental search 
set incsearch 				
"defaults to ignore case search
set ignorecase 
"search will be case sensitive if search pattern contains upper case character
set smartcase 				


" easier than esc
inoremap kd <Esc>
inoremap jj <Esc>
inoremap <A-o> <Esc>

inoremap <A-v> <Esc>v
" alternative to vim ctr-o that goes to normal mode for 1 command
inoremap <A-h> <Esc>hi
inoremap <A-j> <Esc>ji
inoremap <A-k> <Esc>ki
inoremap <A-l> <Esc>li



" Map leader to space. 
" Unbinds the Space key as it's used as the leader key
nnoremap <SPACE> <Nop> 		
let mapleader=" "


" -- delete not cut -- 
nnoremap x "_x
nnoremap X "_X

"nnoremap diw "_diw
"nnoremap ciw "_ciw
"nnoremap diq "_di"
"nnoremap ciq "_ci"
" -- motions -- 
"in vim already: b = ()
"in vim already: B = {}
"quote 
nnoremap caq ca"
nnoremap ciq ci"
nnoremap daq da"
nnoremap diq di"
"array 
nnoremap dia "_di[
nnoremap cia "_ci[
"match
nnoremap dm d%
nnoremap cm c%


"delete line -- replace 'go to previous line'
nnoremap - "_dd				

inoremap ,, <esc>:vsc Window.PreviousTab<CR>
nnoremap ,, <esc>:vsc Window.PreviousTab<CR>


" -- code insert -- 
inoremap jk {<Esc>li
inoremap jl [<Esc>li
inoremap jæ (<Esc>li
inoremap aæ <Esc>A;
inoremap aø <Esc>/[)}"'\]>]<CR>:nohl<CR>a<space>

" require vs-vim to handle control-sequence
"save if file is changed and go to normal mode
inoremap <C-s> <Esc>:update<CR>
" require vs-vim to handle control-sequence
inoremap <C-l> <Esc>:vsc Edit.GoToDefinition<CR>
" require vs-vim to handle control-sequence
inoremap <C-j> <Esc>:vsc Edit.FindAllReferences<CR>

" -- visual 
" -- selection -- 
" multi-line select with ctrl+alt+cursor - works out of the box
" Amazing VS functionality
inoremap <C-I> <Esc>:vsc Edit.ExpandSelection<CR>
nnoremap <C-I> :vsc Edit.ExpandSelection<CR>
vnoremap <C-I> :vsc Edit.ExpandSelection<CR>
vnoremap i :vsc Edit.ExpandSelection<CR>
vnoremap I :vsc Edit.ContractSelection<CR>
"first char
vnoremap H ^
"EOL
vnoremap L g_



"move r to R
nnoremap R r

" -- replace motion --
" replace deletes to register 'a' and paste
nnoremap rw "adiwPw
" we use 'daw' otherwise space between words counts as a word, e.g. "a b" is 3 words
nnoremap r2w "a2dawP
nnoremap r3w "a3dawP
" replace line
nnoremap rl "addPj
nnoremap r2l "a2ddPj

" make the cursor does not jump back to where you started the selection.
vnoremap y ygv<esc>


" -- Normal mode -- 
"delete line -- replace 'go to previous line'
nnoremap - dd				

"go to end of previous word
nnoremap W ge			
vnoremap W ge			


" Changes go to A register, leave my unnamed alone
nnoremap c "ac
nnoremap C "aC
nnoremap d "ad
nnoremap D "aD


"delete word  - replace 'go to top of screen' 
"tempting to remap H to BOL - but we have 'A' or 'C' for that
nnoremap H "_daw	

"down and re-center
nnoremap J 12jzz
vnoremap J 12jzz

"up and re-center
nnoremap K 12kzz
vnoremap K 12kzz

" replace go to bottom of screen
nnoremap L :vsc Edit.GoToDefinition<CR>


" down next block and re-center
nnoremap M }zz
vnoremap M }zz



nnoremap u :vsc Edit.Undo<cr>
nnoremap U :vsc Edit.Redo<cr> 


nnoremap <leader>j J
vnoremap <leader>j J

nnoremap <leader>df :vsc Window.CloseDocumentWindow<CR>
nnoremap <leader>gd :vsc Edit.GoToDefinition<CR>
nnoremap <leader>gc :vsc Edit.GoToDeclaration<CR>
nnoremap <leader>gi :vsc Edit.GoToImplementation<CR>
nnoremap <leader>gr :vsc Edit.FindAllReferences<CR>

nnoremap <leader>p :vsc Edit.GoToNextIssueInFile<CR>
nnoremap <leader>å :vsc Edit.GoToPreviousIssueInFile<CR>

" not sure what we navigate
nnoremap <leader>i :vsc View.NavigateForward<CR>
nnoremap <leader>o :vsc View.NavigateBackward<CR>

"moving tab looses focus.. needs a better way
noremap <leader>J :vsc Window.NextTab<CR>
noremap <leader>K :vsc Window.PreviousTab<CR>

noremap <leader>b :vsc Build.BuildSolution<CR>
noremap <leader>bb :vsc Build.RebuildSolution<CR>

" `<leader> + w(indow) + p(in)` - Toggle the pin status of the document 
" `<leader> + w(indows) + c(lose) + a(ll)` - Close all unpinned documents 
noremap <leader>wp :vsc Window.PinTab<CR>
noremap <leader>wca :vsc Window.CloseAllButPinned<CR>
